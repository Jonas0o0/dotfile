{
    "layer": "top",
    "position": "top",
    "height": 30,
    "margin-top": 0,
    "margin-left": 0,
    "margin-right": 0,
    "spacing": 0,
    "modules-left": ["custom/apple", "custom/weather", "hyprland/workspaces"],
    "modules-center": ["clock"],
    "modules-right": ["network", "pulseaudio", "backlight", "hyprland/language", "battery", "tray"],
    
    "hyprland/language": {
        "format": "{}",
        "format-en": "US",
        "format-fr": "FR",
        "on-click": "hyprctl switchxkblayout all next",
        "tooltip-format": "Layout: {layout}"
    },
    "custom/apple": {
        "format": "яЕ╝",
        "on-click": "fuzzel",
        "tooltip": false
    },
    "custom/weather": {
        "format": "{}",
        "interval": 3600,
        "exec": "ping -c 1 8.8.8.8 > /dev/null && curl -s 'https://wttr.in/?format=%C+%t&lang=fr' || echo 'Hors ligne'"
    },
    "hyprland/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "format": "{name}",
        "on-click": "activate"
    },
    "tray": {
        "icon-size": 16,
        "spacing": 10
    },
    "clock": {
        "format": "{:%A %d %b %H:%M}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt>{calendar}</tt>"
    },
    "backlight": {
        "format": "{icon}",
        "format-icons": ["яЖЕ"],
        "on-scroll-up": "brightnessctl set 5%+",
        "on-scroll-down": "brightnessctl set 5%-",
        "tooltip-format": "Luminosit├й: {percent}%"
    },
    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-charging": "яЧз {capacity}%",
        "format-plugged": "яЗж {capacity}%",
        "format-icons": ["яЙД", "яЙГ", "яЙВ", "яЙБ", "яЙА"],
        "on-click": "notify-send 'Batterie' \"$(acpi -b)\""
    },
    "network": {
        "format-wifi": "яЗл",
        "format-ethernet": "яЮЦ",
        "format-disconnected": "тЪа",
        "tooltip-format": "{ifname} via {gwaddr}",
        "format-linked": "{ifname} (No IP) яЮЦ",
        "tooltip-format-wifi": "Wi-Fi: {essid} ({signalStrength}%)",
        "tooltip-format-ethernet": "Ethernet: {ifname}",
        "on-click": "alacritty -e nmtui"
    },
    "pulseaudio": {
        "format": "{icon}",
        "format-bluetooth": "{icon}яКФ",
        "format-muted": "яЪй",
        "format-icons": {
            "headphone": "яАе",
            "hands-free": "яЦР",
            "headset": "яЦР",
            "phone": "яВХ",
            "portable": "яВХ",
            "car": "яЖ╣",
            "default": ["яАж", "яАз", "яАи"]
        },
        "on-click": "pavucontrol",
        "on-scroll-up": "wpctl set-volume -l 1 @DEFAULT_AUDIO_SINK@ 5%+",
        "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-",
        "tooltip-format": "Volume: {volume}%"
    }
}
